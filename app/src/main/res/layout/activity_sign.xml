<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="#4D4D4D"
    android:gravity="center"
    android:paddingHorizontal="24dp"
    android:paddingTop="40dp"
    android:paddingBottom="32dp"
    tools:context=".Activities.SignActivity">


    <TextView
        android:id="@+id/TituloRegistro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Crear Cuenta"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold" />


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Nombres"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/inputNombres"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/stylearea"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:gravity="center_vertical"
        android:hint="Ingresa tus nombres"
        android:inputType="textPersonName"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="#050505"
        android:textColorHint="#AAAAAA"
        android:textSize="16sp" />


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Apellidos"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/inputApellidos"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/stylearea"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:gravity="center_vertical"
        android:hint="Ingresa tus apellidos"
        android:inputType="textPersonName"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="#050505"
        android:textColorHint="#AAAAAA"
        android:textSize="16sp" />


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Correo Electrónico"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/inputCorreo"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/stylearea"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:gravity="center_vertical"
        android:hint="correo@ejemplo.com"
        android:inputType="textEmailAddress"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="#050505"
        android:textColorHint="#AAAAAA"
        android:textSize="16sp" />


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Contraseña"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/inputPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/stylearea"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:gravity="center_vertical"
        android:hint="Ingresa tu contraseña"
        android:inputType="textPassword"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="#050505"
        android:textColorHint="#AAAAAA"
        android:textSize="16sp" />


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Repetir Contraseña"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/inputPasswordRepeat"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/stylearea"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:gravity="center_vertical"
        android:hint="Repite tu contraseña"
        android:inputType="textPassword"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="#050505"
        android:textColorHint="#AAAAAA"
        android:textSize="16sp" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <CheckBox
            android:id="@+id/checkTerminos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#23B6E2"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="Acepto los "
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtTerminos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="términos y condiciones"
            android:textColor="#B3F306"
            android:textSize="14sp" />

    </LinearLayout>


    <Button
        android:id="@+id/btnRegistro"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#23B6E2"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Registrarse"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:stateListAnimator="@null" />


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="¿Ya tienes cuenta? "
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtVolverLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="Inicia sesión"
            android:textColor="#B3F306"
            android:textSize="16sp" />

    </LinearLayout>

</LinearLayout>