<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:background="@color/fondo_inicio"
    tools:context=".Activities.Auth.LoginActivity">

    <LinearLayout
        android:layout_width="309dp"
        android:layout_height="66dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/logoapp"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:contentDescription="@string/nombre_app"
            app:srcCompat="@mipmap/logoapp_foreground" />

        <TextView
            android:id="@+id/NombreApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="@string/nombre_app"
            android:textColor="@color/texto_principal"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/TextoIntroduccion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="@string/texto_bienvenida"
        android:textAlignment="center"
        android:textColor="@color/texto_principal"
        android:textSize="18sp"
        android:textStyle="normal" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageView
            android:id="@+id/userypasword"
            android:layout_width="wrap_content"
            android:layout_height="143dp"
            android:layout_marginEnd="10dp"
            android:contentDescription="@string/hint_usuario"
            app:srcCompat="@mipmap/userypassword" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/ingresarusuario"
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/stylearea"
                android:fontFamily="@font/tiro_devanagari_hindi"
                android:gravity="center_vertical"
                android:hint="@string/hint_usuario"
                android:inputType="textEmailAddress"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/texto_oscuro"
                android:textColorHint="@color/texto_hint"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/ingresarpassword"
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:background="@drawable/stylearea"
                android:fontFamily="@font/tiro_devanagari_hindi"
                android:gravity="center_vertical"
                android:hint="@string/hint_contrasena"
                android:inputType="textPassword"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/texto_oscuro"
                android:textColorHint="@color/texto_hint"
                android:textSize="16sp" />

        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnIngresar"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/boton_primario"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="@string/boton_ingresar"
        android:textColor="@color/texto_principal"
        android:textSize="22sp"
        android:textStyle="bold"
        android:stateListAnimator="@null" />

    <TextView
        android:id="@+id/ingresarHuella"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="@string/ingresar_con_huella_dactilar"
        android:textAlignment="center"
        android:textColor="@color/texto_accion"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/recuperarcontraseña"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="@string/recuperar_contrasena"
        android:textAlignment="center"
        android:textColor="@color/texto_accion"
        android:textSize="16sp" />

    <LinearLayout
        android:id="@+id/IngresoGoogle"
        android:layout_width="260dp"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_button_google"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/google"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="10dp"
            android:contentDescription="@string/ingresar_google"
            app:srcCompat="@mipmap/google" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="@string/ingresar_google"
            android:textColor="@color/texto_oscuro"
            android:textSize="18sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/NoTienesCuenta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="@string/no_tienes_cuenta"
            android:textColor="@color/texto_principal"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/RegistratePregunta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="@string/registrate"
            android:textColor="@color/texto_accion"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>