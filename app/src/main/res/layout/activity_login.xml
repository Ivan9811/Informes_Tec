<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:background="#4D4D4D"
    tools:context=".Activities.LoginActivity">


    <LinearLayout
        android:layout_width="309dp"
        android:layout_height="66dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/logoapp"
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:srcCompat="@mipmap/logoapp_foreground" />

        <TextView
            android:id="@+id/NombreApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="Informes Tec"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>


    <TextView
        android:id="@+id/TextoIntroduccion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="La aventura está por iniciar, por favor inicia sesión"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="normal" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">


        <ImageView
            android:id="@+id/userypasword"
            android:layout_width="wrap_content"
            android:layout_height="143dp"
            android:layout_marginEnd="10dp"
            app:srcCompat="@mipmap/userypassword" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <EditText
                android:id="@+id/ingresarusuario"
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/stylearea"
                android:fontFamily="@font/tiro_devanagari_hindi"
                android:gravity="center_vertical"
                android:hint="Usuario"
                android:inputType="textEmailAddress"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#050505"
                android:textColorHint="#AAAAAA"
                android:textSize="16sp" />


            <EditText
                android:id="@+id/ingresarpassword"
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:background="@drawable/stylearea"
                android:fontFamily="@font/tiro_devanagari_hindi"
                android:gravity="center_vertical"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#050505"
                android:textColorHint="#AAAAAA"
                android:textSize="16sp" />

        </LinearLayout>
    </LinearLayout>


    <Button
        android:id="@+id/btnIngresar"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#23B6E2"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Ingresar"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:stateListAnimator="@null" />


    <TextView
        android:id="@+id/recuperarcontraseña"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Recupera Tu Contraseña"
        android:textAlignment="center"
        android:textColor="#B3F306"
        android:textSize="16sp" />


    <LinearLayout
        android:id="@+id/IngresoGoogle"
        android:layout_width="260dp"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_button_google"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/google"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="10dp"
            app:srcCompat="@mipmap/google" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="Ingresa con Google"
            android:textColor="#050505"
            android:textSize="18sp" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/NoTienesCuenta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="No tienes cuenta? "
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/RegistratePregunta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="Regístrate"
            android:textColor="#B3F306"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>