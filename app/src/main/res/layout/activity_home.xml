<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/fondo_inicio"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    tools:context=".Activities.inicio.HomeActivity">

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <ImageView
        android:id="@+id/logoapp"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:contentDescription="@string/nombre_app"
        app:srcCompat="@mipmap/logoapp_foreground" />

    <TextView
        android:id="@+id/NombreApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="@string/nombre_app"
        android:textColor="@color/texto_principal"
        android:textSize="42sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/Textodebienvenida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="@string/texto_bienvenida"
        android:textAlignment="center"
        android:textColor="@color/texto_principal"
        android:textSize="20sp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/buttoncomienza"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:backgroundTint="@color/boton_primario"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="@string/boton_comienza"
        android:textColor="@color/texto_principal"
        android:textSize="22sp"
        android:textStyle="bold"
        android:stateListAnimator="@null"
        app:rippleColor="@color/boton_onda" />

    <TextView
        android:id="@+id/Registrate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="32dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="@string/registrate"
        android:textColor="@color/texto_registrate"
        android:textSize="20sp" />

</LinearLayout>
