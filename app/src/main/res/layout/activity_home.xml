<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#4D4D4D"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    tools:context=".Activities.HomeActivity">


    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />


    <ImageView
        android:id="@+id/logoapp"
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:srcCompat="@mipmap/logoapp_foreground" />


    <TextView
        android:id="@+id/NombreApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Informes Tec"
        android:textColor="#FFFFFF"
        android:textSize="42sp"
        android:textStyle="bold" />


    <TextView
        android:id="@+id/Textodebienvenida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Inicia una nueva aventura con Informes Tec y descubre una nueva forma de ver el mundo"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="20sp" />


    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />


    <Button
        android:id="@+id/buttoncomienza"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:backgroundTint="#23B6E2"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Comienza"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:stateListAnimator="@null"
        app:rippleColor="#6382DE" />


    <TextView
        android:id="@+id/Registrate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="32dp"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="Regístrate"
        android:textColor="#B3F306"
        android:textSize="20sp" />

</LinearLayout>
